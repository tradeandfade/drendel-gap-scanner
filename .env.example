# Drendel Gap Scanner Configuration
# Copy this to .env and fill in your values.
# Or just use the Setup Guide tab in the dashboard.

# Alpaca API Keys (get these at alpaca.markets)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Paper trading (recommended) or live
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Server port (default 8000)
PORT=8000
